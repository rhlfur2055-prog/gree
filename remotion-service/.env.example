# 그리 Shorts 파이프라인 환경변수
# cp .env.example .env 후 채워서 사용

# ── TTS (선택, ElevenLabs 우선 시도 → OpenAI fallback) ──────────
# ElevenLabs: 한국어 품질 최상, eleven_multilingual_v2 사용
ELEVENLABS_API_KEY=

# OpenAI: TTS fallback + Whisper 자막 추출에 필수
OPENAI_API_KEY=

# ── 선택사항 ────────────────────────────────────────────────────
# 기본 TTS voice (ElevenLabs는 voice ID, OpenAI는 alloy/echo/fable/onyx/nova/shimmer)
TTS_VOICE=alloy

# Whisper 언어 (기본 ko)
WHISPER_LANGUAGE=ko
